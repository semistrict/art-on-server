From: art-host fork <ramon@echophase.com>
Subject: [PATCH] Add arm64 Linux build-host support

The build system hardcodes x86_64 as the only Linux build host
architecture. Soong already detects arm64 hosts (PrebuiltOS() returns
linux-arm64, microfactory.bash selects prebuilts/go/linux-arm64), and
prebuilts/build-tools ships a native linux-arm64 directory — only the
make-side detection is missing. Recognize aarch64 in HOST_ARCH, and make
HOST_PREBUILT_TAG resolve to linux-arm64 so prebuilt lookups (JDK,
build-tools, misc) use the arm64 directories.
---
diff --git a/core/envsetup.mk b/core/envsetup.mk
index f82e861abf..b595d4669f 100644
--- a/core/envsetup.mk
+++ b/core/envsetup.mk
@@ -176,6 +176,10 @@ ifneq (,$(findstring x86_64,$(UNAME)))
   HOST_ARCH := x86_64
   HOST_2ND_ARCH := x86
   HOST_IS_64_BIT := true
+else ifneq (,$(findstring aarch64,$(UNAME)))
+  HOST_ARCH := arm64
+  HOST_2ND_ARCH :=
+  HOST_IS_64_BIT := true
 else
 ifneq (,$(findstring i686,$(UNAME))$(findstring x86,$(UNAME)))
 $(error Building on a 32-bit x86 host is not supported: $(UNAME)!)
@@ -245,7 +249,11 @@ endif
 endif
 
 # We don't want to move all the prebuilt host tools to a $(HOST_OS)-x86_64 dir.
-HOST_PREBUILT_ARCH := x86
+ifeq ($(HOST_ARCH),arm64)
+  HOST_PREBUILT_ARCH := arm64
+else
+  HOST_PREBUILT_ARCH := x86
+endif
 # This is the standard way to name a directory containing prebuilt host
 # objects. E.g., prebuilt/$(HOST_PREBUILT_TAG)/cc
 # This must match the logic in get_host_prebuilt_prefix in envsetup.sh
diff --git a/envsetup.sh b/envsetup.sh
index 444048fc9b..2b9c9d7e88 100644
--- a/envsetup.sh
+++ b/envsetup.sh
@@ -133,7 +133,11 @@ function get_host_prebuilt_prefix
 {
   local un=$(uname)
   if [[ $un == "Linux" ]] ; then
-    echo linux-x86
+    if [[ $(uname -m) == "aarch64" ]] ; then
+      echo linux-arm64
+    else
+      echo linux-x86
+    fi
   elif [[ $un == "Darwin" ]] ; then
     echo darwin-x86
   else
