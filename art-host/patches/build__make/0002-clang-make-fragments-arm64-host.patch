From: art-host fork <ramon@echophase.com>
Subject: [PATCH] clang make fragments for arm64 Linux build hosts

LLVM_RTLIB_PATH/LLVM_READOBJ hardcoded the linux-x86 prebuilt dir; use
HOST_PREBUILT_TAG. Add the HOST_arm64.mk fragment pointing at the
aarch64-unknown-linux-musl runtime archives of the linux-arm64 clang.
---
diff --git a/core/clang/HOST_arm64.mk b/core/clang/HOST_arm64.mk
new file mode 100644
index 0000000000..2109fd982a
--- /dev/null
+++ b/core/clang/HOST_arm64.mk
@@ -0,0 +1,4 @@
+# Clang config for an arm64 Linux build host (linux_musl-arm64). The runtime
+# archives live in the per-triple directory of the linux-arm64 clang prebuilt.
+HOST_LIBPROFILE_RT := $(LLVM_RTLIB_PATH)/aarch64-unknown-linux-musl/libclang_rt.profile.a
+HOST_LIBCRT_BUILTINS := $(LLVM_RTLIB_PATH)/aarch64-unknown-linux-musl/libclang_rt.builtins.a
diff --git a/core/clang/config.mk b/core/clang/config.mk
index d03c5417d2..2e134e857c 100644
--- a/core/clang/config.mk
+++ b/core/clang/config.mk
@@ -1,8 +1,8 @@
 ## Clang configurations.
 
-LLVM_READOBJ := $(LLVM_PREBUILTS_BASE)/$(BUILD_OS)-x86/$(LLVM_PREBUILTS_VERSION)/bin/llvm-readobj
+LLVM_READOBJ := $(LLVM_PREBUILTS_BASE)/$(HOST_PREBUILT_TAG)/$(LLVM_PREBUILTS_VERSION)/bin/llvm-readobj
 
-LLVM_RTLIB_PATH := $(LLVM_PREBUILTS_BASE)/linux-x86/$(LLVM_PREBUILTS_VERSION)/lib/clang/$(LLVM_RELEASE_VERSION)/lib/linux/
+LLVM_RTLIB_PATH := $(LLVM_PREBUILTS_BASE)/$(HOST_PREBUILT_TAG)/$(LLVM_PREBUILTS_VERSION)/lib/clang/$(LLVM_RELEASE_VERSION)/lib/linux/
 
 define convert-to-clang-flags
 $(strip $(filter-out $(CLANG_CONFIG_UNKNOWN_CFLAGS),$(1)))
