From: art-host fork <ramon@echophase.com>
Subject: [PATCH] skip framework boot-image profile when frameworks/base absent

Full-platform products on the thin master-art manifest reference
frameworks/base/boot/boot-image-profile.txt which does not exist there;
guard with wildcard so hostdex jars build.
---
diff --git a/target/product/runtime_libart.mk b/target/product/runtime_libart.mk
index 71138ac560..32455e8086 100644
--- a/target/product/runtime_libart.mk
+++ b/target/product/runtime_libart.mk
@@ -80,7 +80,11 @@ ifeq (,$(TARGET_BUILD_UNBUNDLED))
   # frameworks/base may not be present.
   # TODO(b/179900989): We may not need this check once we stop using full
   # platform products on the thin ART manifest branch.
-  PRODUCT_DEX_PREOPT_BOOT_IMAGE_PROFILE_LOCATION += frameworks/base/boot/boot-image-profile.txt
+  # art-host fork: also skip when frameworks/base is absent entirely (thin
+  # master-art checkout building full-platform host products).
+  ifneq (,$(wildcard frameworks/base/boot/boot-image-profile.txt))
+    PRODUCT_DEX_PREOPT_BOOT_IMAGE_PROFILE_LOCATION += frameworks/base/boot/boot-image-profile.txt
+  endif
 endif
 
 # The dalvik.vm.dexopt.thermal-cutoff property must contain one of the values
