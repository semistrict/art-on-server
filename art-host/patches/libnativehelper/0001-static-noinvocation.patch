From: art-host fork <ramon@echophase.com>
Subject: [PATCH] libnativehelper_static_noinvocation

Static libnativehelper without JniInvocation.c, whose dlopen-dispatching
JNI_CreateJavaVM would clash with static libart's real one.
---
diff --git a/Android.bp b/Android.bp
index 7550873..534ab04 100644
--- a/Android.bp
+++ b/Android.bp
@@ -256,3 +256,34 @@ subdirs = [
     "tests",
     "tests_mts",
 ]
+
+// art-host fork: static libnativehelper for the fully static host dalvikvm
+// (dalvikvms). Excludes JniInvocation.c - its dlopen-dispatching
+// JNI_CreateJavaVM would clash with the statically linked libart's real one.
+cc_library_static {
+    name: "libnativehelper_static_noinvocation",
+    defaults: ["libnativehelper_defaults"],
+    host_supported: true,
+    device_supported: false,
+    srcs: [
+        "DlHelp.c",
+        "ExpandableString.c",
+        "JNIHelp.c",
+        "JNIPlatformHelp.c",
+        "JniConstants.c",
+        "file_descriptor_jni.c",
+    ],
+    export_include_dirs: [
+        "header_only_include",
+        "include",
+        "include_jni",
+        "include_platform",
+        "include_platform_header_only",
+    ],
+    visibility: [
+        "//art/dalvikvm",
+        "//external/icu/android_icu4j/libcore_bridge/src/native",
+        "//libcore",
+    ],
+    stl: "none",
+}
